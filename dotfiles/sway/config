set $mod Mod4
set $service_mode service
set $dashboard_mode dashboard

input "type:keyboard" {
    xkb_layout us
    xkb_variant alt-intl
    repeat_delay 150
    repeat_rate 80
}

input "65261:0:DreaM117er_Explorer_Keyboard_Blank_Mouse" {
    accel_profile adaptive
    pointer_accel -0.1
}

output HDMI-A-1 mode 2560x1440@119.998Hz
output * bg '$HOME/Documents/Wallpapers/workspace.jpg' fill

floating_modifier $mod normal
workspace_layout default
default_orientation horizontal

default_border pixel 1
default_floating_border pixel 1

client.focused #ffffff #000000 #ffffff #ffffff #ffffff
client.focused_inactive #4d4d4d #111111 #9a9a9a #4d4d4d #4d4d4d
client.unfocused #2b2b2b #111111 #7a7a7a #2b2b2b #2b2b2b
client.urgent #ffffff #000000 #000000 #ffffff #ffffff
client.placeholder #1a1a1a #1a1a1a #666666 #1a1a1a #1a1a1a
client.background #000000

gaps inner 8
gaps outer 8

exec --no-startup-id dbus-update-activation-environment --systemd DISPLAY WAYLAND_DISPLAY SWAYSOCK XDG_CURRENT_DESKTOP=sway XDG_SESSION_DESKTOP=sway DESKTOP_SESSION=sway
exec --no-startup-id systemctl --user import-environment DISPLAY WAYLAND_DISPLAY SWAYSOCK XDG_CURRENT_DESKTOP XDG_SESSION_DESKTOP DESKTOP_SESSION
exec --no-startup-id wl-paste --type text --watch cliphist store
exec --no-startup-id wl-paste --type image --watch cliphist store
exec --no-startup-id sh -c "swaymsg swaymsg workspace M && swaymsg workspace T && swaymsg workspace W && swaymsg workspace X && swaymsg workspace B"
exec --no-startup-id swayidle -w \
    timeout 600 'swaymsg "output * dpms off" && $HOME/.nix-profile/bin/python3 $HOME/.config/sway/lock.py' \
    resume 'swaymsg "output * dpms on"' \
    before-sleep '$HOME/.nix-profile/bin/python3 $HOME/.config/sway/lock.py'

exec_always --no-startup-id sh -c 'systemctl --user restart xdg-desktop-portal-wlr.service xdg-desktop-portal-gtk.service xdg-desktop-portal.service >/dev/null 2>&1 || true'
exec_always --no-startup-id sh -c 'pkill -x .mako-wrapped >/dev/null 2>&1 || true; $HOME/.nix-profile/bin/mako'
exec_always --no-startup-id sh -c 'killall eww 2>/dev/null; sleep 0.5; eww daemon'

bindsym Ctrl+semicolon mode "$service_mode"

bindsym Mod1+h focus left
bindsym Mod1+j focus down
bindsym Mod1+k focus up
bindsym Mod1+l focus right

bindsym Mod1+Shift+h move left
bindsym Mod1+Shift+j move down
bindsym Mod1+Shift+k move up
bindsym Mod1+Shift+l move right

bindsym $mod+q kill
bindsym $mod+Shift+q exec "swaymsg exit"
bindsym $mod+space exec "wofi --show drun"
bindsym $mod+p exec "eww update selected-index=0; eww open dashboard; swaymsg mode dashboard"
bindsym $mod+Shift+p exec "eww close dashboard && swaymsg mode default"
bindsym $mod+v exec "sh -c 'cliphist list | wofi --dmenu --prompt Clipboard | cliphist decode | wl-copy'"

bindsym $mod+Shift+l exec "$HOME/.nix-profile/bin/python3 $HOME/.config/sway/lock.py"
bindsym $mod+Shift+s exec "$HOME/.nix-profile/bin/python3 $HOME/.config/sway/screenshot-menu.py"

mode "$dashboard_mode" {
    bindsym Ctrl+n exec "sh -lc 'i=$(eww get selected-index); eww update selected-index=$(( (i+1) % 6 ))'"
    bindsym Ctrl+p exec "sh -lc 'i=$(eww get selected-index); eww update selected-index=$(( (i+5) % 6 ))'"

    bindsym Return exec "~/.config/eww/scripts/nav-execute; eww close dashboard; eww update selected-index=0; swaymsg mode default"
    bindsym Escape exec "eww close dashboard; eww update selected-index=0", mode "default"
}

mode "$service_mode" {
    bindsym Escape mode "default"

    bindsym r reload, mode "default"

    bindsym f floating toggle, mode "default"
    bindsym u sticky toggle, mode "default"

    bindsym b workspace B, mode "default"
    bindsym w workspace W, mode "default"
    bindsym m workspace M, mode "default"
    bindsym t workspace T, mode "default"
    bindsym x workspace X, mode "default"

    bindsym Shift+b move container to workspace B, mode "default"
    bindsym Shift+w move container to workspace W, mode "default"
    bindsym Shift+m move container to workspace M, mode "default"
    bindsym Shift+t move container to workspace T, mode "default"
    bindsym Shift+x move container to workspace X, mode "default"

    bindsym minus resize shrink width 50 px or 50 ppt
    bindsym equal resize grow width 50 px or 50 ppt
}

for_window [app_id="kitty"] move container to workspace T, workspace T
for_window [title="Chromium - Bruno"] move container to workspace B, workspace B
for_window [title="Chromium - Squibler"] move container to workspace W, workspace W
for_window [title="YouTube Music"] move container to workspace M, workspace M

for_window [title="Picture-in-picture"] floating enable, sticky enable
for_window [title="Bitwarden"] floating enable
for_window [app_id="eww"] floating enable, border none
