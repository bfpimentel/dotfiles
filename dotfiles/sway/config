set $mod Mod4
set $service_mode service

input type:keyboard {
    xkb_layout us
    xkb_variant intl
    repeat_delay 150
    repeat_rate 80
}

output HDMI-A-1 mode 2560x1440@119.998Hz
output * bg '$HOME/.config/wallpapers/morning.jpg' fill

floating_modifier $mod normal
workspace_layout default
default_orientation horizontal

default_border pixel 1
default_floating_border pixel 1

client.focused #ffffff #000000 #ffffff #ffffff #ffffff
client.focused_inactive #4d4d4d #111111 #9a9a9a #4d4d4d #4d4d4d
client.unfocused #2b2b2b #111111 #7a7a7a #2b2b2b #2b2b2b
client.urgent #ffffff #000000 #000000 #ffffff #ffffff
client.placeholder #1a1a1a #1a1a1a #666666 #1a1a1a #1a1a1a
client.background #000000

gaps inner 8
gaps outer 8

exec --no-startup-id dbus-update-activation-environment --systemd DISPLAY WAYLAND_DISPLAY SWAYSOCK XDG_CURRENT_DESKTOP=sway
exec --no-startup-id systemctl --user import-environment DISPLAY WAYLAND_DISPLAY SWAYSOCK XDG_CURRENT_DESKTOP
exec --no-startup-id wl-paste --type text --watch cliphist store
exec --no-startup-id wl-paste --type image --watch cliphist store

exec_always --no-startup-id sh -c 'systemctl --user restart xdg-desktop-portal.service >/dev/null 2>&1 || true; pkill -x .waybar-wrapped >/dev/null 2>&1 || pkill -f "$HOME/.nix-profile/bin/waybar" >/dev/null 2>&1 || true; XDG_CURRENT_DESKTOP=sway $HOME/.nix-profile/bin/waybar'
exec_always --no-startup-id sh -c 'pkill -x .mako-wrapped >/dev/null 2>&1 || true; $HOME/.nix-profile/bin/mako'

bindsym Ctrl+semicolon mode "$service_mode"

bindsym Mod1+h focus left
bindsym Mod1+j focus down
bindsym Mod1+k focus up
bindsym Mod1+l focus right

bindsym Mod1+Shift+h move left
bindsym Mod1+Shift+j move down
bindsym Mod1+Shift+k move up
bindsym Mod1+Shift+l move right

bindsym $mod+space exec "wofi --show drun"
bindsym $mod+q kill
bindsym $mod+Shift+l exec "$HOME/.config/sway/lock.sh"
bindsym $mod+p exec "$HOME/.config/sway/global-menu.sh"
bindsym $mod+v exec "sh -c 'cliphist list | wofi --dmenu --prompt Clipboard | cliphist decode | wl-copy'"

mode "$service_mode" {
    bindsym Escape mode "default"

    bindsym r reload, mode "default"
    bindsym f floating toggle, mode "default"

    bindsym b workspace B, mode "default"
    bindsym w workspace W, mode "default"
    bindsym m workspace M, mode "default"
    bindsym t workspace T, mode "default"
    bindsym x workspace X, mode "default"

    bindsym Shift+b move container to workspace B, mode "default"
    bindsym Shift+w move container to workspace W, mode "default"
    bindsym Shift+m move container to workspace M, mode "default"
    bindsym Shift+t move container to workspace T, mode "default"
    bindsym Shift+x move container to workspace X, mode "default"

    bindsym minus resize shrink width 50 px or 50 ppt
    bindsym equal resize grow width 50 px or 50 ppt
}

for_window [app_id="kitty"] move container to workspace T
for_window [title="(?i).*Youtube Music.*"] move container to workspace M

for_window [app_id="brave-browser" title="(?i).*Picture(-| )in(-| )Picture.*"] floating enable, sticky enable
for_window [app_id="brave-browser" title="(?i).*Bitwarden.*"] floating enable
