# Name: Everforest Dark Soft
# Description: A soft green-based syntax highlighting theme for Fish

# Syntax Highlighting Colors
set -g fish_color_normal d3c6aa
set -g fish_color_command a7c080
set -g fish_color_keyword d699b6
set -g fish_color_quote dbbc7f
set -g fish_color_redirection 83c092
set -g fish_color_end e69875
set -g fish_color_error e67e80
set -g fish_color_param 7fbbb3
set -g fish_color_comment 859289
set -g fish_color_selection --background=5c6a72
set -g fish_color_search_match --background=5c6a72
set -g fish_color_operator a7c080
set -g fish_color_escape d699b6
set -g fish_color_autosuggestion 859289

# Completion Pager Colors
set -g fish_pager_color_progress 859289
set -g fish_pager_color_prefix a7c080
set -g fish_pager_color_completion d3c6aa
set -g fish_pager_color_description 859289
set -g fish_pager_color_selected_background --background=5c6a72
