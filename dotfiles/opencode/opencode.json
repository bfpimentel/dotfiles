{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [],
  "small_model": "opencode/gpt-5-nano",
  "mcp": {
    "exa": {
      "enabled": false
    },
    "searxng": {
      "enabled": true,
      "type": "local",
      "command": ["npx", "-y", "mcp-searxng"],
      "environment": {
        "SEARXNG_URL": "https://search.local.jalotopimentel.com"
      }
    },
    "nixos": {
      "type": "local",
      "command": ["nix", "run", "github:utensils/mcp-nixos", "--"]
    },
    "home-assistant": {
      "url": "https://home.local.jalotopimentel.com/api/mcp",
      "type": "remote",
      "oauth": false,
      "headers": {
        "Authorization": "Bearer {env:HASS_TOKEN}"
      }
    }
  },
  "provider": {
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio",
      "options": {
        "baseURL": "http://127.0.0.1:1234/v1"
      },
      "models": {
        "qwen/qwen3-coder-30b": {
          "name": "Qwen3 Coder 30B"
        }
      }
    }
  },
  "shell": "zsh"
}

