{
  "layer": "top",
  "position": "top",
  "height": 30,
  "spacing": 8,
  "modules-left": [
    "custom/global-menu",
    "sway/workspaces"
  ],
  "modules-center": [
    "sway/window"
  ],
  "modules-right": [
    "sway/mode",
    "clock"
  ],
  "sway/workspaces": {
    "disable-scroll": true,
    "alphabetical_sort": true,
    "format": "{name}",
    "persistent-workspaces": {
      "B": [],
      "T": [],
      "M": [],
      "W": [],
      "X": []
    }
  },
  "sway/window": {
    "max-length": 70
  },
  "sway/mode": {
    "format": "[S]",
    "tooltip": false
  },
  "clock": {
    "format": "{:%a %d %b %H:%M}"
  },
  "custom/global-menu": {
    "format": "󰿦",
    "tooltip": false,
    "on-click": "~/.config/sway/global-menu.py"
  }
}
